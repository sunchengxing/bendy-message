# Cloudflare Workers
CF_ACCOUNT_ID=your_cf_account_id
CF_D1_DATABASE_ID=your_d1_database_id
CF_KV_CACHE_ID=your_kv_cache_namespace_id
CF_KV_SERVICES_ID=your_kv_services_namespace_id
REGISTRATION_SECRET=your_registration_secret_key

# Vercel
DATABASE_URL=postgresql://user:password@host:5432/bendy_message
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
VERCEL_REGION=auto

# General
RUST_LOG=info
